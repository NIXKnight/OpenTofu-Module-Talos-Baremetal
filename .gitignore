# Local .terraform / OpenTofu working directories
**/.terraform/*
.terraform/

# Provider lock files (resolved per root module; not pinned in a reusable module)
.terraform.lock.hcl

# State and state backups
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Variable files that may contain secrets.
# NOTE: example *.tf files ARE tracked; only *.tfvars are ignored.
*.tfvars
*.tfvars.json

# Local override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config and saved plans
.terraformrc
terraform.rc
*.tfplan
